ANTHROPIC_API_KEY=your_key_here
LINKEDIN_EMAIL=your_linkedin_email
LINKEDIN_PASSWORD=your_linkedin_password
INDEED_EMAIL=your_indeed_email
INDEED_PASSWORD=your_indeed_password

# Used when a job board forces account creation before applying.
# Pick something unique to job boards, not a password you use elsewhere.
JOB_BOARD_PASSWORD=ChangeMe2026!

# Optional address fields used for signup / application forms.
CANDIDATE_CITY=Dallas
CANDIDATE_STATE=TX
CANDIDATE_ZIP=75080
CANDIDATE_COUNTRY=United States

# Optional. Leave blank to have the agent skip forms that require it.
CANDIDATE_DOB=
